[
  {
    "role": "system",
    "content": {
      "protocol": "AISIP V1.0.0",
      "id": "example_greeting",
      "name": "Greeting Assistant",
      "version": "1.0.0",
      "summary": "Simple greeting flow — classify user intent and respond.",
      "description": "AISIP reference example. Demonstrates process, decision, and end nodes with type-free inference.",
      "tools": [],
      "params": { "language": "en", "tone": "friendly" },
      "system_prompt": "{system_prompt}"
    }
  },
  {
    "role": "user",
    "content": {
      "instruction": "RUN aisip.main",
      "user_input": "{user_input}",
      "aisip": {
        "main": {
          "greet":    { "next": ["classify"] },
          "classify": { "branches": { "question": "search", "chat": "reply" } },
          "search":   { "next": ["end"] },
          "reply":    { "next": ["end"] },
          "end":      {}
        }
      },
      "functions": {
        "greet":    { "step1": "Say hello to the user and understand their needs" },
        "classify": { "step1": "Classify user intent as 'question' or 'chat'" },
        "search":   { "step1": "Search for relevant info and compile answer" },
        "reply":    { "step1": "Generate a friendly chat reply" },
        "end":      { "step1": "Output final response to user" }
      }
    }
  }
]
